# GitLab Watcher — Configuration
# Copier ce fichier vers config.yaml et remplir les valeurs.

# URL de votre instance GitLab
gitlab_url: "https://gitlab.example.com"

# Personal Access Token (Settings > Access Tokens, scope: read_api)
private_token: "glpat-xxxxxxxxxxxxxxxxxxxx"

# ID(s) du/des projet(s) — numérique ou "group/project"
# Un seul projet :
#   project_ids: 12345
# Plusieurs projets :
#   project_ids:
#     - 12345
#     - "my-group/my-project"
project_ids: 12345

# Intervalle de polling en secondes (défaut: 60)
poll_interval: 60

# État des MR à afficher : opened, closed, merged, all
mr_state: "opened"

# Nombre de MR à afficher (défaut: 20)
per_page: 20
